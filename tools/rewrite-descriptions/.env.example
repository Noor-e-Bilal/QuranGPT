# ── Required ─────────────────────────────────────────────────────────────
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── Optional ─────────────────────────────────────────────────────────────
# For OpenAI-compatible APIs (Groq, Together AI, OpenRouter, local LLMs, etc.)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_BASE_URL=http://localhost:1234/v1

# Model to use (default: gpt-4o-mini — cheap & fast)
# REWRITE_MODEL=gpt-4o-mini
# REWRITE_MODEL=llama-3.3-70b-versatile

# Descriptions per API call (default: 3, reduce for long descriptions)
# REWRITE_BATCH_SIZE=3
