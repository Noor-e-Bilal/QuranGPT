# LLM — Anthropic-compatible endpoint via opencode.ai (used for query reformulation)
ANTHROPIC_BASE_URL=https://opencode.ai/zen
ANTHROPIC_MODEL=minimax-m2.5-free
ANTHROPIC_API_KEY=your_api_key_here

# ── User-selectable LLM providers ────────────────────────────────────────────

# Claude (Anthropic) — provider: "claude"
# Base URL defaults to https://api.anthropic.com; set to override
# CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI — provider: "openai"
# Models: gpt-4o | gpt-4o-mini | gpt-4.1
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter — provider: "openrouter"
# Models: google/gemini-2.5-flash-preview:free | meta-llama/llama-4-maverick:free | ...
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ChromaDB (Docker service)
CHROMA_URL=http://localhost:8000

# SQLite canonical store (relative to apps/web/ when running npm dev)
DB_PATH=../../data/quran.db

# Optional: override base URL for internal SSR fetches
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
